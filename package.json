{
  "name": "flo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker-compose up",
    "dev:down": "docker-compose down",
    "dev:build": "docker-compose up --build",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.18.0",
    "husky": "latest",
    "lint-staged": "^15.5.2",
    "prettier": "latest",
    "typescript-eslint": "^8.59.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
